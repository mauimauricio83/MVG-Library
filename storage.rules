rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public site fetches the published catalog snapshot with a plain,
    // deterministic URL (no rotating download token needed) since read
    // access is unconditionally public here -- see fetchData()/SNAPSHOT_URL
    // in app.js. Only signed-in admins (per the `admins` Firestore
    // collection) can write a new snapshot, via the "Publish" button in the
    // admin panel.
    match /catalog/snapshot.json {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }
  }
}
