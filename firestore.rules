rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public site never talks to Firestore directly (it reads the published
    // JSON snapshot from Cloud Storage instead) -- only the admin panel does,
    // and only for signed-in admins.
    match /videos/{rowNum} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // meta/counters holds the next-available rowNum, atomically incremented
    // via a transaction when adding entries -- lets Add/Bulk Import reserve
    // fresh IDs without scanning the whole `videos` collection for the max.
    match /meta/{doc} {
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // A signed-in user may read their OWN admin doc (to decide whether to show
    // admin UI) but can never write it -- prevents client-side privilege
    // escalation. Assigning admins is a manual Firebase Console / Admin SDK action.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Unchanged -- each signed-in user reads/writes only their own favorites/
    // recently-viewed doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
